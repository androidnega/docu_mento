APP_NAME=Docu Mento
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/Docu_Mento/public

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Use mysql for production (cPanel). SQLite supported for local; file created if missing.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Docu_Mento
DB_USERNAME=root
DB_PASSWORD=

OPENAI_API_KEY=

# Secret for URL-based run-migrations / fix-pull / clear-cache (live only). Default: DocuMentoMigrate2026Xp9k3m7
# Use: https://your-domain.com/run-migrations?key=YOUR_SECRET&action=fixpull
MIGRATION_RUN_KEY=

# Arkesel SMS OTP (student login). Optional if set in Admin → Settings → OTP.
# Get key from https://sms.arkesel.com/dashboard (SMS API). Use on live/cPanel if DB key fails.
ARKESEL_API_KEY=

# Staff: set and run php artisan db:seed
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_NAME=

EXAMINER_USERNAME=
EXAMINER_PASSWORD=
EXAMINER_NAME=
EXAMINER_COURSE_ID=

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=docu-mento
REVERB_APP_KEY=quizsnap-key
REVERB_APP_SECRET=quizsnap-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
